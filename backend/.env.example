OPENAI_API_KEY=your-openai-api-key

# Supabase project settings (optional for this backend unless you call Supabase APIs directly).
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database URL from Supabase (Transaction pooler or direct Postgres URL).
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<host>:5432/postgres

# Model settings
S2S_MODEL=gpt-4o-realtime-preview
S2S_VOICE=alloy
CHAT_MODEL=gpt-4o

# Query limits
CONVERSATION_HISTORY_LIMIT=5
REVIEW_HISTORY_LIMIT=5
LEVEL_EVAL_SESSION_LIMIT=10
PROGRESS_NOTES_SESSION_LIMIT=5
QUICK_REVIEW_LIMIT=5

# Profile constraints
MAX_EXAMPLES_PER_PATTERN=5
MAX_PATTERNS_FOR_REVIEW=3
MAX_EXAMPLES_FOR_REVIEW=3
